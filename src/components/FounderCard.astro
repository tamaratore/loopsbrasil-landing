---
interface Props {
  nome: string;
  papel: string;
  cidade: string;
}
const { nome, papel, cidade } = Astro.props;
---
<div class="rounded-2xl border border-ink-line bg-ink-raised p-6">
  <span class="text-xs font-semibold uppercase tracking-[0.15em] text-brand-purple">{nome}</span>
  <p class="mt-2 text-sm text-paper/60">{papel}</p>
  <p class="mt-1 text-xs text-paper/40">{cidade}</p>
</div>
