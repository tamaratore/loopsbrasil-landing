---
interface Props {
  nome: string;
  papel: string;
  cidade: string;
  handle?: string;
}
const { nome, papel, cidade, handle } = Astro.props;
---
<div class="rounded-2xl border border-ink-line bg-ink-raised p-6">
  <span class="text-xs font-semibold uppercase tracking-[0.15em] text-brand-purple">{nome}</span>
  <p class="mt-2 text-sm text-paper/60">{papel}</p>
  <p class="mt-1 flex flex-wrap items-center gap-x-2 text-xs text-paper/40">
    <span>{cidade}</span>
    {handle && <span>{handle}</span>}
  </p>
</div>
