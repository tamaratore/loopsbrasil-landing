---
interface Logo {
  nome: string;
  href: string;
  logo: string;
  logoW: number;
  logoH: number;
  heightClass: string;
}

interface Props {
  tag: string;
  title: string;
  subtitle: string;
  logos?: Logo[];
}
const { tag, title, subtitle, logos } = Astro.props;
---
<section class="relative overflow-hidden px-6 pt-16 pb-14 sm:pt-24 sm:pb-20">
  <div
    class="pointer-events-none absolute -right-24 -top-24 h-72 w-72 rounded-full bg-brand-purple/20 blur-3xl"
    aria-hidden="true"
  >
  </div>
  <div class="relative mx-auto max-w-2xl text-center">
    <p class="text-xs font-semibold uppercase tracking-[0.2em] text-brand-red">{tag}</p>
    <h1 class="balance mt-4 font-display text-3xl uppercase leading-snug text-paper sm:text-4xl">
      {title}
    </h1>
    <p class="mt-5 text-lg text-paper/70">{subtitle}</p>

    {logos && logos.length > 0 && (
      <div class="mt-8 flex flex-wrap items-center justify-center gap-x-8 gap-y-4">
        {logos.map((l) => (
          <a href={l.href} target="_blank" rel="noopener noreferrer" aria-label={l.nome}>
            <img
              src={l.logo}
              alt={l.nome}
              class={`${l.heightClass} w-auto opacity-70 grayscale transition hover:opacity-100 hover:grayscale-0`}
              width={l.logoW}
              height={l.logoH}
              loading="lazy"
            />
          </a>
        ))}
      </div>
    )}
  </div>
</section>
