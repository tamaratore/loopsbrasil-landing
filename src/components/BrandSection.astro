---
interface Marca {
  nome: string;
  desc: string;
  href: string;
  accent: string;
  logo?: string;
  logoW?: number;
  logoH?: number;
}

interface Props {
  marcas: Marca[];
}
const { marcas } = Astro.props;
---
<section class="px-6 py-14">
  <div class="mx-auto max-w-4xl">
    <h2 class="font-display text-3xl text-paper">As marcas da rede</h2>
    <div class="mt-8 flex flex-wrap justify-center gap-4">
      {marcas.map((m) => (
        <a
          href={m.href}
          target="_blank"
          rel="noopener noreferrer"
          class="glow-card flex w-full flex-col rounded-2xl border border-ink-line bg-ink-raised p-6 sm:w-[calc(50%-0.5rem)] lg:w-[calc(33.333%-0.667rem)]"
        >
          {m.logo ? (
            <img
              src={m.logo}
              alt={`Logo ${m.nome}`}
              class="mb-3 h-9 w-auto self-start"
              width={m.logoW}
              height={m.logoH}
              loading="lazy"
            />
          ) : (
            <span class={`text-xs font-semibold uppercase tracking-[0.15em] text-${m.accent}`}>
              {m.nome}
            </span>
          )}
          <p class="mt-2 text-sm text-paper/60">{m.desc}</p>
        </a>
      ))}
    </div>
  </div>
</section>
