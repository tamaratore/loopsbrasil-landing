---
interface Brand {
  nome: string;
  desc: string;
  href: string;
}

interface Props {
  atual: string;
}

const { atual } = Astro.props;

const REDE: Brand[] = [
  { nome: 'Rede Loops Brasil', desc: 'Hub da rede: todas as marcas num lugar só', href: 'https://loopsbrasil.com.br' },
  { nome: 'ED Tutoriais', desc: 'Cursos de produção musical', href: 'https://edtutoriais.com.br' },
  { nome: 'Samples Brasil', desc: 'Loops, waves e pacotes Kontakt prontos', href: 'https://samplesbrasil.com' },
  { nome: 'EM Music Produções', desc: 'Grava, mixa e masteriza com o Eder Machado', href: 'https://emmusicproducoes.com.br' },
  { nome: 'Eder Machado', desc: 'Música e clipes do Eder Machado', href: 'https://eder.edtmusic.com.br' },
];
---

<header class="sticky top-0 z-50 border-b border-ink-line bg-ink/95 backdrop-blur">
  <div class="mx-auto flex max-w-5xl items-center justify-between px-4 py-2.5 sm:px-6">
    <span class="text-xs font-semibold uppercase tracking-[0.15em] text-paper/50">{atual}</span>
    <details class="rede-switcher relative">
      <summary class="flex cursor-pointer list-none items-center gap-1.5 rounded-full border border-ink-line px-3 py-1.5 text-xs font-semibold text-paper/80 transition hover:border-paper/40 hover:text-paper">
        Conhecer a rede
        <svg viewBox="0 0 24 24" class="h-3 w-3 fill-current"><path d="M7 10l5 5 5-5z"></path></svg>
      </summary>
      <div class="absolute right-0 z-50 mt-2 w-72 max-w-[calc(100vw-2rem)] rounded-2xl border border-ink-line bg-ink-raised p-2 shadow-xl">
        {REDE.map((b) => (
          b.nome === atual ? (
            <div class="block rounded-xl bg-ink px-3 py-2.5">
              <p class="text-sm font-semibold text-paper">
                {b.nome}
                <span class="ml-1.5 text-[10px] font-normal uppercase tracking-wide text-paper/40">você está aqui</span>
              </p>
              <p class="mt-0.5 text-xs text-paper/50">{b.desc}</p>
            </div>
          ) : (
            <a href={b.href} class="block rounded-xl px-3 py-2.5 transition hover:bg-ink">
              <p class="text-sm font-semibold text-paper">{b.nome}</p>
              <p class="mt-0.5 text-xs text-paper/50">{b.desc}</p>
            </a>
          )
        ))}
      </div>
    </details>
  </div>
</header>

<script>
  document.querySelectorAll('.rede-switcher').forEach((el) => {
    document.addEventListener('click', (e) => {
      if (!el.contains(e.target as Node)) el.removeAttribute('open');
    });
    el.addEventListener('keydown', (e) => {
      if ((e as KeyboardEvent).key === 'Escape') el.removeAttribute('open');
    });
  });
</script>
