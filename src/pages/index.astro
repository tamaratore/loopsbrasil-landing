---
import Base from '../layouts/Base.astro';
import RedeFooter from '../components/RedeFooter.astro';

// marcas reais da Rede Loops Brasil (confirmadas 17/07, EDTMusic no ar desde 21/07)
const marcas = [
  {
    nome: 'ED Tutoriais',
    desc: 'Loops, waves e pacotes Kontakt em real (BRL), direto com quem já produz há anos.',
    href: 'https://edtutoriais.com.br',
    accent: 'brand-purple',
    logo: '/images/edtutoriais-logo.png',
    logoW: 80,
    logoH: 38,
  },
  {
    nome: 'Samples Brasil',
    desc: 'Loops, waves e pacotes Kontakt em dólar/euro, pra arrastar na tua DAW.',
    href: 'https://samplesbrasil.com',
    accent: 'brand-red',
    logo: '/images/samplesbrasil-logo.png',
    logoW: 200,
    logoH: 43,
  },
  {
    nome: 'EM Music Produções',
    desc: 'Grava, mixa e masteriza com o Eder Machado. Piseiro, arrocha, pagode, axé.',
    href: 'https://emmusicproducoes.com.br',
    accent: 'brand-green',
    logo: '/images/em-music-logo.png',
    logoW: 578,
    logoH: 240,
  },
  {
    nome: 'EDTMusic',
    desc: 'Selo e editora: direitos autorais, contratos e arrecadação musical.',
    href: 'https://edtmusic.com.br',
    accent: 'brand-orange',
    logo: '/images/edtmusic-logo.png',
    logoW: 753,
    logoH: 160,
  },
  {
    nome: 'Academia Loops Brasil',
    desc: 'Cursos de produção fonográfica. Hoje são os cursos da ED Tutoriais, em breve integrados.',
    href: 'https://academia.loopsbrasil.com.br',
    accent: 'brand-red',
  },
];

const fundadores = [
  {
    nome: 'Eder Machado',
    papel: 'Fundador ED Tutoriais, Sócio e Fundador Loops Brasil',
  },
  {
    nome: 'Tamara Toré',
    papel: 'Sócia e CEO ED Tutoriais, Sócia e Fundadora Loops Brasil',
  },
];

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Rede Loops Brasil',
  url: 'https://rede.loopsbrasil.com.br',
  logo: 'https://rede.loopsbrasil.com.br/images/loopsbrasil-logo.png',
  sameAs: marcas.map((m) => m.href),
  founder: fundadores.map((f) => ({
    '@type': 'Person',
    name: f.nome,
  })),
};
---
<Base
  title="Rede Loops Brasil"
  description="ED Tutoriais, Samples Brasil, EM Music Produções e EDTMusic: cursos, loops, produção musical e selo, tudo numa rede só."
  image="/images/loopsbrasil-logo.png"
  ogType="website"
  structuredData={structuredData}
  redeAtual="Rede Loops Brasil"
>
  <main>
    <!-- HERO -->
    <section class="relative flex flex-col items-center justify-center overflow-hidden px-6 py-16 sm:py-24">
      <div
        class="pointer-events-none absolute -right-24 -top-24 h-72 w-72 rounded-full bg-brand-purple/20 blur-3xl"
        aria-hidden="true"
      >
      </div>
      <div class="relative mx-auto max-w-xl text-center">
        <img
          src="/images/loopsbrasil-logo.png"
          alt="Rede Loops Brasil"
          class="mx-auto h-10 w-auto sm:h-12"
          width="746"
          height="371"
        />

        <div class="mx-auto mt-6 flex h-10 items-end justify-center gap-1" aria-hidden="true">
          <span class="eq-bar w-1.5 rounded-full bg-gradient-to-t from-brand-purple to-brand-red"></span>
          <span class="eq-bar w-1.5 rounded-full bg-gradient-to-t from-brand-purple to-brand-red"></span>
          <span class="eq-bar w-1.5 rounded-full bg-gradient-to-t from-brand-purple to-brand-red"></span>
          <span class="eq-bar w-1.5 rounded-full bg-gradient-to-t from-brand-purple to-brand-red"></span>
          <span class="eq-bar w-1.5 rounded-full bg-gradient-to-t from-brand-purple to-brand-red"></span>
          <span class="eq-bar w-1.5 rounded-full bg-gradient-to-t from-brand-purple to-brand-red"></span>
          <span class="eq-bar w-1.5 rounded-full bg-gradient-to-t from-brand-purple to-brand-red"></span>
        </div>

        <p class="mt-[5px] font-body text-sm font-semibold uppercase tracking-[0.2em] text-brand-red">
          Rede Loops Brasil
        </p>
        <h1 class="balance mt-[5px] font-hero text-5xl uppercase leading-[1.3] text-paper sm:text-6xl sm:leading-[1.3] md:text-7xl md:leading-[1.3]">
          Samples, loops e cursos de produção musical
        </h1>
        <p class="balance mt-[5px] text-lg text-paper/70">
          E um selo pra lançar sua música no Spotify, Deezer e mais.
        </p>

        <a
          href="#as-marcas"
          class="mt-8 inline-flex items-center gap-2.5 rounded-full bg-gradient-to-r from-brand-purple to-brand-red px-8 py-4 font-accent text-lg uppercase tracking-wide text-paper"
        >
          Conhecer as marcas
        </a>
      </div>
    </section>

    <!-- MARCAS -->
    <section id="as-marcas" class="px-6 py-14">
      <div class="mx-auto max-w-4xl">
        <h2 class="font-display text-3xl text-paper">As marcas</h2>
        <div class="mt-8 flex flex-wrap justify-center gap-4">
          {marcas.map((m) => (
            <a
              href={m.href}
              target="_blank"
              rel="noopener noreferrer"
              class={`glow-card flex w-full flex-col rounded-2xl bg-ink-raised p-6 sm:w-[calc(50%-0.5rem)] lg:w-[calc(33.333%-0.667rem)]`}
            >
              {m.logo ? (
                <img
                  src={m.logo}
                  alt={`Logo ${m.nome}`}
                  class="mb-3 h-9 w-auto self-start"
                  width={m.logoW}
                  height={m.logoH}
                  loading="lazy"
                />
              ) : (
                <span class={`text-xs font-semibold uppercase tracking-[0.15em] text-${m.accent}`}>
                  {m.nome}
                </span>
              )}
              <p class="mt-2 text-sm text-paper/60">{m.desc}</p>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- QUEM SOMOS -->
    <section class="px-6 py-14">
      <div class="mx-auto max-w-4xl">
        <h2 class="font-display text-3xl text-paper">Quem somos</h2>
        <p class="mt-4 max-w-2xl text-sm text-paper/60">
          A Rede Loops Brasil nasceu da parceria entre Eder Machado, fundador da ED Tutoriais,
          e Tamara Toré, sócia e CEO da ED Tutoriais. Juntos, tocam as marcas acima.
        </p>
        <div class="mt-8 grid gap-4 sm:grid-cols-2">
          {fundadores.map((f) => (
            <div class="glow-card rounded-2xl bg-ink-raised p-6">
              <span class="text-xs font-semibold uppercase tracking-[0.15em] text-brand-purple">
                {f.nome}
              </span>
              <p class="mt-2 text-sm text-paper/60">{f.papel}</p>
            </div>
          ))}
        </div>
        <a
          href="/nossa-historia"
          class="mt-6 inline-block text-sm font-semibold text-brand-red underline-offset-4 transition hover:underline"
        >
          Ler mais sobre a gente
        </a>
      </div>
    </section>

    <!-- RODAPÉ -->
    <footer class="border-t border-ink-line px-6 py-12">
      <div class="mx-auto max-w-4xl">
        <RedeFooter atual="Rede Loops Brasil" />
      </div>
    </footer>
  </main>
</Base>
