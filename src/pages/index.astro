---
import Base from '../layouts/Base.astro';

// marcas reais da Rede Loops Brasil (confirmadas 17/07). EDTMusic (selo) ainda não
// tem site/domínio próprio: aparece como "em breve", sem link quebrado.
const marcas = [
  {
    nome: 'ED Tutoriais',
    desc: 'Cursos de produção musical, direto com quem já produz há anos.',
    href: 'https://edtutoriais.com.br',
    accent: 'brand-purple',
  },
  {
    nome: 'Samples Brasil',
    desc: 'Loops, waves e pacotes Kontakt prontos pra arrastar na tua DAW.',
    href: 'https://samplesbrasil.com',
    accent: 'brand-red',
  },
  {
    nome: 'EM Music Produções',
    desc: 'Grava, mixa e masteriza com o Eder Machado. Piseiro, arrocha, pagode, axé.',
    href: 'https://emmusicproducoes.com.br',
    accent: 'brand-green',
    logo: '/images/em-music-logo.png',
  },
  {
    nome: 'Eder Machado',
    desc: 'Últimos lançamentos, clipes e onde ouvir nas plataformas digitais.',
    href: 'https://eder.edtmusic.com.br',
    accent: 'brand-purple',
  },
];

const emBreve = {
  nome: 'EDTMusic',
  desc: 'Selo e editora: direitos autorais, contratos e arrecadação musical.',
  logo: '/images/edtmusic-logo.png',
};

const fundadores = [
  {
    nome: 'Tamara Toré',
    papel: 'Sócia-fundadora — operação, produto e tecnologia',
  },
  {
    nome: 'Eder Machado',
    papel: 'Sócio-fundador — produção musical e conteúdo',
  },
];

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Rede Loops Brasil',
  url: 'https://loopsbrasil.com.br',
  logo: 'https://loopsbrasil.com.br/images/loopsbrasil-logo.png',
  sameAs: marcas.map((m) => m.href),
  founder: fundadores.map((f) => ({
    '@type': 'Person',
    name: f.nome,
  })),
};
---
<Base
  title="Rede Loops Brasil"
  description="ED Tutoriais, Samples Brasil, EM Music Produções e EDTMusic: cursos, loops, produção musical e selo, tudo numa rede só."
  image="/images/loopsbrasil-logo.png"
  ogType="website"
  structuredData={structuredData}
>
  <main>
    <!-- HERO -->
    <section class="relative overflow-hidden px-6 pt-16 pb-14 sm:pt-24 sm:pb-20">
      <div
        class="pointer-events-none absolute -right-24 -top-24 h-72 w-72 rounded-full bg-brand-purple/20 blur-3xl"
        aria-hidden="true"
      >
      </div>
      <div class="relative mx-auto max-w-xl text-center">
        <img
          src="/images/loopsbrasil-logo.png"
          alt="Rede Loops Brasil"
          class="mx-auto h-20 w-auto sm:h-24"
          width="800"
          height="340"
        />
        <p class="mt-6 text-lg text-paper/70">
          Cursos, loops, produção musical e selo. Tudo separado por marca, tudo na mesma rede.
        </p>
      </div>
    </section>

    <!-- MARCAS -->
    <section class="px-6 py-14">
      <div class="mx-auto max-w-4xl">
        <h2 class="font-display text-3xl text-paper">As marcas</h2>
        <div class="mt-8 grid gap-4 sm:grid-cols-2">
          {marcas.map((m) => (
            <a
              href={m.href}
              target="_blank"
              rel="noopener noreferrer"
              class={`glow-card flex flex-col rounded-2xl border border-ink-line bg-ink-raised p-6`}
            >
              {m.logo && (
                <img
                  src={m.logo}
                  alt={`Logo ${m.nome}`}
                  class="mb-3 h-14 w-auto self-start"
                  width="578"
                  height="240"
                  loading="lazy"
                />
              )}
              <span class={`text-xs font-semibold uppercase tracking-[0.15em] text-${m.accent}`}>
                {m.nome}
              </span>
              <p class="mt-2 text-sm text-paper/60">{m.desc}</p>
            </a>
          ))}

          <div class="flex flex-col rounded-2xl border border-dashed border-ink-line p-6 opacity-60">
            {emBreve.logo && (
              <img
                src={emBreve.logo}
                alt={`Logo ${emBreve.nome}`}
                class="mb-3 h-10 w-auto self-start"
                width="753"
                height="160"
                loading="lazy"
              />
            )}
            <span class="text-xs font-semibold uppercase tracking-[0.15em] text-paper/50">
              {emBreve.nome} (em breve)
            </span>
            <p class="mt-2 text-sm text-paper/50">{emBreve.desc}</p>
          </div>
        </div>
      </div>
    </section>

    <!-- QUEM SOMOS -->
    <section class="px-6 py-14">
      <div class="mx-auto max-w-4xl">
        <h2 class="font-display text-3xl text-paper">Quem somos</h2>
        <p class="mt-4 max-w-2xl text-sm text-paper/60">
          A Rede Loops Brasil nasceu da parceria entre Tamara Toré e Eder Machado: uma cuida da
          operação, do produto e da tecnologia; o outro, da produção musical e do conteúdo.
          Juntos, tocam as marcas acima.
        </p>
        <div class="mt-8 grid gap-4 sm:grid-cols-2">
          {fundadores.map((f) => (
            <div class="rounded-2xl border border-ink-line bg-ink-raised p-6">
              <span class="text-xs font-semibold uppercase tracking-[0.15em] text-brand-purple">
                {f.nome}
              </span>
              <p class="mt-2 text-sm text-paper/60">{f.papel}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- RODAPÉ -->
    <footer class="border-t border-ink-line px-6 py-10">
      <div class="mx-auto flex max-w-4xl flex-col items-center gap-3 text-center">
        <p class="text-xs uppercase tracking-[0.2em] text-paper/40">Rede Loops Brasil</p>
      </div>
    </footer>
  </main>
</Base>
