---
import Base from '../layouts/Base.astro';
import InstitutionalHero from '../components/InstitutionalHero.astro';
import StorySection from '../components/StorySection.astro';
import BrandStorySection from '../components/BrandStorySection.astro';
import AcademiaSection from '../components/AcademiaSection.astro';
import FounderBioSection from '../components/FounderBioSection.astro';
import SocialProofSection from '../components/SocialProofSection.astro';
import CommunitySection from '../components/CommunitySection.astro';
import PrinciplesSection from '../components/PrinciplesSection.astro';
import InstitutionalCTA from '../components/InstitutionalCTA.astro';
import RedeFooter from '../components/RedeFooter.astro';

// conteúdo institucional oficial passado por Toré em 21/07 - texto completo
// (história, marcas, bios, missão/visão/valores) preservado como enviado, só
// ajustando nome civil completo + "conhecido profissionalmente como" pra bater
// com as regras 2 e 3 das feedback_regras_institucionais_marca_21_07 (que ela
// mesma definiu). Nenhum fato, data ou relação foi alterado.
const fundadores = [
  {
    nome: 'Eder Machado',
    papel: 'Fundador ED Tutoriais, Sócio e Fundador Loops Brasil',
    cidade: 'Goiânia, GO',
    handle: '@prod_eder_machado',
  },
  {
    nome: 'Tamara Toré',
    papel: 'Sócia e CEO ED Tutoriais, Sócia e Fundadora Loops Brasil',
    cidade: 'Rio de Janeiro, RJ',
    handle: '@tamaratore',
  },
];

const sameAs = [
  'https://edtutoriais.com.br',
  'https://samplesbrasil.com',
  'https://emmusicproducoes.com.br',
  'https://edtmusic.com.br',
  'https://academia.loopsbrasil.com.br',
];

// Schema.org - só campos reais confirmados, sem data de fundação inventada (regra 11)
const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Loops Brasil',
  url: 'https://rede.loopsbrasil.com.br/nossa-historia',
  founder: [
    { '@type': 'Person', name: 'Eder Machado' },
    { '@type': 'Person', name: 'Tamara Toré' },
  ],
  sameAs,
};
---
<Base
  title="Sobre | Loops Brasil"
  description="Conheça a história da Loops Brasil, fundada por Eder Machado e Tamara Toré, e descubra como música, tecnologia, educação e amizade deram origem a uma grande comunidade musical."
  image="/images/loopsbrasil-logo.png"
  ogType="website"
  structuredData={structuredData}
  redeAtual="Rede Loops Brasil"
>
  <main>
    <InstitutionalHero
      tag="Loops Brasil"
      title="Sobre"
      subtitle="Música brasileira, tecnologia e conhecimento unidos para facilitar a criação de produtores e artistas."
    />
    <StorySection fundadores={fundadores} />
    <BrandStorySection />
    <AcademiaSection />
    <FounderBioSection />
    <SocialProofSection />
    <CommunitySection />
    <PrinciplesSection />
    <InstitutionalCTA
      texto="Quer conhecer de perto o que cada marca da rede faz?"
      href="/#as-marcas"
      label="Conhecer as marcas"
    />
    <footer class="border-t border-ink-line px-6 py-12">
      <div class="mx-auto max-w-3xl text-center">
        <p class="text-sm text-paper/50">
          A Loops Brasil foi fundada por Eder Machado e Tamara Toré, amigos,
          sócios e parceiros de trabalho. Juntos, unem música, educação,
          produção, audiovisual e tecnologia para desenvolver instrumentos,
          cursos, conteúdos e projetos que facilitam a vida de produtores,
          músicos e artistas. A Loops Brasil está construindo uma grande
          comunidade musical baseada em amizade, escuta, dedicação e respeito
          por cada pessoa que faz parte dessa história.
        </p>
      </div>
      <div class="mx-auto mt-8 max-w-4xl">
        <RedeFooter atual="Rede Loops Brasil" />
      </div>
    </footer>
  </main>
</Base>
