---
import '../styles/global.css';
import RedeSwitcher from '../components/RedeSwitcher.astro';
import Preloader from '../components/Preloader.astro';
import SideTabs from '../components/SideTabs.astro';

interface Props {
  title: string;
  description: string;
  image?: string;
  ogType?: string;
  structuredData?: Record<string, unknown>;
  redeAtual?: string;
}
const { title, description, image, ogType = 'website', structuredData, redeAtual } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImage = image ? new URL(image, Astro.site).toString() : undefined;
---
<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:locale" content="pt_BR" />
    {ogImage && <meta property="og:image" content={ogImage} />}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}

    {structuredData && (
      <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
    )}

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Anton&family=Poppins:wght@300;400;500;600;700;800&family=Lato:wght@400;700&family=Abel&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-black text-paper font-body antialiased">
    <Preloader />
    <div id="site-nav-wrap" class="nav-overlay-gradient fixed inset-x-0 top-0 z-50">
      {redeAtual && <RedeSwitcher atual={redeAtual} />}
      <slot name="nav" />
    </div>
    {redeAtual && <SideTabs siteLabel={redeAtual} />}
    <slot />

    <script>
      const navWrap = document.getElementById('site-nav-wrap');
      if (navWrap) {
        const onScroll = () => {
          navWrap.classList.toggle('nav-solid', window.scrollY > 80);
        };
        onScroll();
        window.addEventListener('scroll', onScroll, { passive: true });
      }
    </script>
  </body>
</html>
